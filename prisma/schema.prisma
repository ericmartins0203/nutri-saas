generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  NUTRITIONIST
  CLIENT
}

enum ClientStatus {
  ACTIVE
  PAUSED
  FINISHED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  CANCELED
}

enum CheckInFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
}

enum CheckInQuestionType {
  WEIGHT
  SCALE
  TEXT
  BOOLEAN
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  nutritionistProfile NutritionistProfile?
  clientProfile       ClientProfile?
}

model NutritionistProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  crn       String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  clients          ClientProfile[]
  invites          Invite[]
  checkInTemplates CheckInTemplate[]
}

model ClientProfile {
  id             String       @id @default(cuid())
  userId         String?      @unique
  nutritionistId String
  name           String
  email          String?
  phone          String?
  birthDate      DateTime?
  height         Decimal?     @db.Decimal(5, 2)
  initialWeight  Decimal?     @db.Decimal(5, 2)
  currentGoal    String?
  restrictions   String?
  preferences    String?
  notes          String?
  status         ClientStatus @default(ACTIVE)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user         User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  nutritionist NutritionistProfile  @relation(fields: [nutritionistId], references: [id], onDelete: Cascade)
  invites      Invite[]

  @@index([nutritionistId])
}

model Invite {
  id             String       @id @default(cuid())
  nutritionistId String
  clientId       String
  token          String       @unique
  expiresAt      DateTime
  acceptedAt     DateTime?
  status         InviteStatus @default(PENDING)
  createdAt      DateTime     @default(now())

  nutritionist NutritionistProfile @relation(fields: [nutritionistId], references: [id], onDelete: Cascade)
  client       ClientProfile       @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([nutritionistId])
  @@index([clientId])
}

model CheckInTemplate {
  id             String           @id @default(cuid())
  nutritionistId String
  title          String
  description    String?
  frequency      CheckInFrequency @default(MONTHLY)
  active         Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  nutritionist NutritionistProfile @relation(fields: [nutritionistId], references: [id], onDelete: Cascade)
  questions    CheckInQuestion[]

  @@index([nutritionistId])
}

model CheckInQuestion {
  id         String              @id @default(cuid())
  templateId String
  text       String
  type       CheckInQuestionType
  required   Boolean             @default(false)
  order      Int
  active     Boolean             @default(true)
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  template CheckInTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
}
